# ============================================================
# RLM Memory MCP Server Configuration
# Copy this file to .env and choose ONE provider mode below.
# ============================================================

# ------------------------------------------------------------
# Option A: OpenAI Codex CLI auth (no external LLM API key)
# Requires local Codex CLI to be installed and authenticated.
# Good for Codex users who already use `codex auth login` / web auth.
# ------------------------------------------------------------
# LLM_PROVIDER=codex
# CODEX_MODEL=gpt-5.5
# CODEX_SANDBOX=read-only
# CODEX_IGNORE_USER_CONFIG=true
# CODEX_IGNORE_RULES=true
# LLM_TIMEOUT_MS=120000

# Optional but useful on Windows if spawning `codex` directly is unreliable:
# CODEX_COMMAND=C:\nvm4w\nodejs\node.exe
# CODEX_ENTRYPOINT=C:\nvm4w\nodejs\node_modules\@openai\codex\bin\codex.js

# Optional: project root passed to `codex exec -C`.
# For global installs, prefer setting this in a project-local Codex config.
# CODEX_CWD=C:\path\to\your\repo

# ------------------------------------------------------------
# Option B: OpenRouter — one key, any model
# Get a key at: https://openrouter.ai/keys
# Default model: google/gemini-3.5-flash
# ------------------------------------------------------------
# OPENROUTER_API_KEY=""

# ------------------------------------------------------------
# Option C: Google Gemini direct
# Get a key at: https://aistudio.google.com/
# Default model: gemini-3.5-flash
# ------------------------------------------------------------
# GEMINI_API_KEY=""

# ------------------------------------------------------------
# Optional LLM tuning (sensible defaults, usually leave as-is)
# ------------------------------------------------------------
# Which provider to use: auto (default) | codex | openrouter | gemini
# "auto" picks OpenRouter if OPENROUTER_API_KEY is set, else Gemini.
# LLM_PROVIDER=auto

# Override the model for the active provider, e.g.:
#   OpenRouter: google/gemini-3.5-flash, anthropic/claude-haiku-4.5, openai/gpt-4o-mini
#   Gemini direct: gemini-3.5-flash, gemini-3-flash-preview
# LLM_MODEL=google/gemini-3.5-flash

# Thinking effort for the model: minimal | low (default) | medium | high
# Low keeps the MCP's helper calls fast and cheap.
# LLM_REASONING_EFFORT=low

# Max output tokens per call (default 4096)
# LLM_MAX_TOKENS=4096

# Per-request timeout in milliseconds (default 60000)
# LLM_TIMEOUT_MS=60000

# ------------------------------------------------------------
# Server options
# ------------------------------------------------------------
# Web UI port (default 3848) — npm start, then open http://localhost:3848
# UI_PORT=3848

# Where project memories are stored.
# Default: <install dir>/projects. Set this to keep your data outside
# the install tree so it survives reinstalls/updates.
# RLM_DATA_DIR=C:\Users\you\rlm-data

# NOTE: If no API key is set the server still works — all tools fall
# back to keyword-based matching (less smart, but functional).
